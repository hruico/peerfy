# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8000

# REQUIRED in production: restrict WebSocket CORS to your domain.
# Example: https://peerfy.example.com
ALLOWED_ORIGIN=https://your-domain.com

# Optional vault limits (defaults shown)
MAX_MEMBERS=10
MAX_ROOMS=500
ROOM_TTL_MS=14400000   # 4 hours in milliseconds

# ── Client (Vite build-time env vars) ─────────────────────────────────────────
# Leave blank to use the same origin as the server (recommended for production).
VITE_BACKEND_URL=

# TURN server for peer connections behind symmetric NAT (corporate/mobile networks).
# Without TURN, ~15% of peer connections will silently fail.
# Recommended providers: Metered, Twilio, coturn (self-hosted)
VITE_TURN_URL=turn:your-turn-server.example.com:3478
VITE_TURN_USER=your-turn-username
VITE_TURN_CREDENTIAL=your-turn-credential
